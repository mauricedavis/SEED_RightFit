{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Apex Tests",
      "type": "apex",
      "request": "launch",
      "logFile": "${workspaceFolder}/.sfdx/tools/apex.log"
    },
    {
      "name": "Launch LWC Jest Tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/sfdx-lwc-jest",
      "args": ["--runInBand"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}

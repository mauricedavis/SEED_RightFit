    <recordLookups>
        <description>Gets the contact record associated with this match criteria</description>
        <name>Get_Contact_Record</name>
        <label>Get Contact Record</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Get_Matching_Schools</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Student__r.Id</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Contact</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Matching_Schools</name>
        <label>Get Matching Schools</label>
        <locationX>176</locationX>
        <locationY>431</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Filter_College_Gap</targetReference>
        </connector>
        <filterLogic>(1 OR 2) AND 3 AND 4 AND ((5 AND 6 AND 7 AND 8) OR (9 AND 10) OR 23) AND (11 OR 12 OR 13 OR 14 OR 15 OR 16 OR 17 OR 18) AND (19 OR 20 OR 21) AND 22</filterLogic>
        <filters>
            <field>Right_Fit_Match_Color_Automatic__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>SEEDMatchingYellow</elementReference>
            </value>
        </filters>
        <filters>
            <field>Right_Fit_Match_Color_Automatic__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>SEEDMatchGreenConstant</elementReference>
            </value>
        </filters>
        <filters>
            <field>Median_GPA__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>GPAHighMatch</elementReference>
            </value>
        </filters>
        <filters>
            <field>Median_GPA__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>GPAMatchLow</elementReference>
            </value>
        </filters>
        <filters>
            <field>Median_SAT_Math__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>MatchHighSATMath</elementReference>
            </value>
        </filters>
        <filters>
            <field>Median_SAT_Math__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>MatchLowSATMath</elementReference>
            </value>
        </filters>
        <filters>
            <field>Median_SAT_Verbal__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>MatchHighSATVerbal</elementReference>
            </value>
        </filters>
        <filters>
            <field>Median_SAT_Verbal__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>MatchLowSATVerbal</elementReference>
            </value>
        </filters>
        <filters>
            <field>Median_ACT_Composite__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>ACTCompHigh</elementReference>
            </value>
        </filters>
        <filters>
            <field>Median_ACT_Composite__c</field>
            <operator>GreaterThanOrEqualTo</operator>
            <value>
                <elementReference>ACTCompLow</elementReference>
            </value>
        </filters>
        <filters>
            <field>Geographical_Region__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>FarWestStudentDecision</elementReference>
            </value>
        </filters>
        <filters>
            <field>Geographical_Region__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>RockyMountains</elementReference>
            </value>
        </filters>
        <filters>
            <field>Geographical_Region__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Southeast</elementReference>
            </value>
        </filters>
        <filters>
            <field>Geographical_Region__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>MidEast</elementReference>
            </value>
        </filters>
        <filters>
            <field>Geographical_Region__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Southwest</elementReference>
            </value>
        </filters>
        <filters>
            <field>Geographical_Region__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>Plains</elementReference>
            </value>
        </filters>
        <filters>
            <field>Geographical_Region__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>GreatLakes</elementReference>
            </value>
        </filters>
        <filters>
            <field>Geographical_Region__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>NewEngland</elementReference>
            </value>
        </filters>
        <filters>
            <field>College_Size_Formula__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>SizeMedium</elementReference>
            </value>
        </filters>
        <filters>
            <field>College_Size_Formula__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>SizeSmall</elementReference>
            </value>
        </filters>
        <filters>
            <field>College_Size_Formula__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>SizeLarge</elementReference>
            </value>
        </filters>
        <filters>
            <field>College_Setting__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.College_Setting__c</elementReference>
            </value>
        </filters>
        <filters>
            <field>Test_Scores_Optional__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>

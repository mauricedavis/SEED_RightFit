    <description>This flow creates the right fit matches. Adds Test Scores Optional

12.16.2025 (MJD) - Updated flow to trigger on Create AND Update (instead of just Create only).
04.23.2026 — Replace per-iteration SRL Get Records with invocable RightFitMatchListGapAction (avoids 101 SOQL when many schools match).
04.23.2026 — Get Matching Schools: allow zero rows (assign null when not found) so a criteria save does not fail when no colleges match; avoids CANNOT_EXECUTE_FLOW_TRIGGER in the survey screen flow.</description>
    <environments>Default</environments>
    <formulas>
        <description>ACT Composite score high from student match record</description>
        <name>ACTCompHigh</name>
        <dataType>Number</dataType>
        <expression>If( ISPICKVAL( {!$Record.ACT_Composite_Score__c}, &apos;1&apos;), 1,
If( ISPICKVAL( {!$Record.ACT_Composite_Score__c} , &apos;7&apos;), 7,
If( ISPICKVAL( {!$Record.ACT_Composite_Score__c} , &apos;13&apos;), 13,
If( ISPICKVAL( {!$Record.ACT_Composite_Score__c} , &apos;19&apos;), 19,
If( ISPICKVAL( {!$Record.ACT_Composite_Score__c} , &apos;25&apos;), 25,
If( ISPICKVAL( {!$Record.ACT_Composite_Score__c} , &apos;31&apos;), 31,
If( ISPICKVAL( {!$Record.ACT_Composite_Score__c}, &apos;36&apos;), 36,
0)))))))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Low ACT Composite score from student match record</description>
        <name>ACTCompLow</name>
        <dataType>Number</dataType>
        <expression>If( ISPICKVAL( {!$Record.ACT_Score_Low__c}, &apos;1&apos;), 1,
If( ISPICKVAL( {!$Record.ACT_Score_Low__c} , &apos;7&apos;), 7,
If( ISPICKVAL( {!$Record.ACT_Score_Low__c} , &apos;13&apos;), 13,
If( ISPICKVAL( {!$Record.ACT_Score_Low__c} , &apos;19&apos;), 19,
If( ISPICKVAL( {!$Record.ACT_Score_Low__c} , &apos;25&apos;), 25,
If( ISPICKVAL( {!$Record.ACT_Score_Low__c} , &apos;31&apos;), 31,
If( ISPICKVAL( {!$Record.ACT_Score_Low__c}, &apos;36&apos;), 36,
0)))))))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>College size from picklist on match record</description>
        <name>CollegeSize</name>
        <dataType>String</dataType>
        <expression>If( ISPICKVAL( {!$Record.College_Size__c},&quot;Small (Less than 5,000 Students)&quot;), &quot;Small&quot;,
If( ISPICKVAL( {!$Record.College_Size__c}, &quot;Medium (5,000 - 15,000 Students)&quot;), &quot;Medium&quot;,
If( ISPICKVAL( {!$Record.College_Size__c}, &quot;Large (15,000+ Students)&quot;), &quot;Large&quot;,
&quot;&quot;)))</expression>
    </formulas>
    <formulas>
        <name>FarWestStudentDecision</name>
        <dataType>String</dataType>
        <expression>If({!$Record.Far_West__c} = TRUE, &quot;Far West&quot;, &quot;&quot;)</expression>
    </formulas>
    <formulas>
        <name>GPAHighMatch</name>
        <dataType>Number</dataType>
        <expression>If( ISPICKVAL( {!$Record.High_GPA_Accet__c}, &quot;1.0&quot;), 1.0,
If( ISPICKVAL( {!$Record.High_GPA_Accet__c}, &quot;1.5&quot;), 1.5,
If( ISPICKVAL( {!$Record.High_GPA_Accet__c}, &quot;2.0&quot;), 2.0,
If( ISPICKVAL( {!$Record.High_GPA_Accet__c}, &quot;2.5&quot;), 2.5,
If( ISPICKVAL( {!$Record.High_GPA_Accet__c}, &quot;3.0&quot;), 3.0,
If( ISPICKVAL( {!$Record.High_GPA_Accet__c}, &quot;3.5&quot;), 3.5,
If( ISPICKVAL( {!$Record.High_GPA_Accet__c}, &quot;4.0&quot;), 4.0,
If( ISPICKVAL( {!$Record.High_GPA_Accet__c}, &quot;4.5&quot;), 4.5,
If( ISPICKVAL( {!$Record.High_GPA_Accet__c}, &quot;5.0&quot;), 5.0,
0
)))))))))</expression>
        <scale>1</scale>
    </formulas>
    <formulas>

If( ISPICKVAL( {!$Record.Low_GPA_of_Accepted_Students__c}, &quot;2.5&quot;), 2.5,
If( ISPICKVAL( {!$Record.Low_GPA_of_Accepted_Students__c}, &quot;3.0&quot;), 3.0,
If( ISPICKVAL( {!$Record.Low_GPA_of_Accepted_Students__c}, &quot;3.5&quot;), 3.5,
If( ISPICKVAL( {!$Record.Low_GPA_of_Accepted_Students__c}, &quot;4.0&quot;), 4.0,
If( ISPICKVAL( {!$Record.Low_GPA_of_Accepted_Students__c}, &quot;4.5&quot;), 4.5,
If( ISPICKVAL( {!$Record.Low_GPA_of_Accepted_Students__c}, &quot;5.0&quot;), 5.0,

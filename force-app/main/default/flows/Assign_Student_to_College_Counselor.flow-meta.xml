                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_SEED_MD_Students</targetReference>
            </connector>
            <label>SEED MD</label>
        </rules>
        <rules>
            <name>SEED_Miami</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Email</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>student.miami.seedschool.org</stringValue>
                </rightValue>

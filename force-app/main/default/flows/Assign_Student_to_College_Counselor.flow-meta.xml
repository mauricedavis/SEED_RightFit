    <decisions>
        <name>Find_SEED_School_from_Student_Email_Address</name>
        <label>Find SEED School from Student Email Address</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Send_Email_to_Counselor_Assigned_to_Student</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>SEED_DC</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Email</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>student.dc.seedschool.org</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_SEED_DC_Students</targetReference>
            </connector>
            <label>SEED DC</label>
        </rules>
        <rules>
            <name>SEED_MD</name>
            <conditionLogic>and</conditionLogic>
            <conditions>

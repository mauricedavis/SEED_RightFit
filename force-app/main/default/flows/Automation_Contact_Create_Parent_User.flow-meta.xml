    <decisions>
        <name>Does_user_already_exist</name>
        <label>Does user already exist?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Create_Parent_User</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No, user does not exist - create user</defaultConnectorLabel>
        <rules>
            <name>Yes_user_exists_skip_creation</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Id</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Get_Contact_Record_Just_Created.User__r.ContactId</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_Contact_Record_Just_Created.AccountId</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>001i000000ahxTSAAY</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Find_SEED_School_from_Student_Email_Address</targetReference>
            </connector>
            <label>Yes, user exists - skip creation</label>
        </rules>
    </decisions>
    <decisions>
        <name>Find_SEED_School_from_Student_Email_Address</name>
        <label>Find SEED School from Student Email Address</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>

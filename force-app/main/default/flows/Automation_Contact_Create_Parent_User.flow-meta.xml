    <description>When a new parent is added as a Contact, also create the parent User account for them to log into the Right Fit Community portal and see their student&apos;s information.</description>
    <environments>Default</environments>
    <formulas>
        <name>varAlias</name>
        <dataType>String</dataType>
        <expression>LOWER(
    LEFT({!$Record.FirstName}, 2) &amp; 
    LEFT({!$Record.LastName}, 
         IF(LEN({!$Record.LastName}) &lt; 6, LEN({!$Record.LastName}), 6)
    )
)</expression>
    </formulas>
    <formulas>
        <name>varNickname</name>
        <dataType>String</dataType>
        <expression>LEFT(
    {!$Record.FirstName} &amp; &quot; &quot; &amp; {!$Record.LastName}, 
    40
)</expression>
    </formulas>
    <formulas>
        <name>varStudentName</name>
        <dataType>String</dataType>
        <expression>{!$Record.FirstName} + {!$Record.LastName}</expression>
    </formulas>
    <formulas>
        <name>varUserName</name>
        <dataType>String</dataType>
        <expression>{!$Record.Email} + &quot;.student&quot;</expression>
    </formulas>
